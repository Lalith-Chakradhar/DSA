https://leetcode.com/problems/first-unique-character-in-a-string/



class Solution {

    //Algorithm
    //1. Store freqeuency of characters in hashmap.
    //2. Iterate through the characters, if the frequency is 1, return that index.
    public int firstUniqChar(String s) {
        HashMap<Character, Integer> freq = new HashMap<>();
        int n = s.length();
        for(int i=0;i<n;i++)
        {
             char ch = s.charAt(i);
             freq.put(ch, freq.getOrDefault(ch,0)+1);
        }

        for(int i=0; i<n; i++)
        {
                char ch = s.charAt(i);
                if(freq.get(ch) == 1) return i;
        }

        return -1;
    }
}
