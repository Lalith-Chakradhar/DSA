https://www.geeksforgeeks.org/problems/largest-subarray-with-0-sum/1


class Solution {
    
    //Algorithm
    //1. Find the prefix sum of elements.
    //2. While performing the prefix sum, store the prefix sum -> index into hashmap.
    //3. If the current prefix sum is already present in hashmap or if the prefix sum is zero,
    //then find the length using current prefixSum - already present prefixSum.
    //4. Find the max length and return it.
    
    int maxLength(int arr[]) {
        // code here
        HashMap<Integer, Integer> hm = new HashMap<>();
        
        hm.put(0,-1);
        
        int n = arr.length;
        int prefixSum = 0;
        int maxLength = 0;
        for(int i=0; i<n; i++)
        {
            prefixSum += arr[i];
            
            int length = 0;
            if(hm.containsKey(prefixSum))
            {
                length = i - hm.get(prefixSum);
                maxLength = Math.max(length, maxLength);
            }
            else
            {
                hm.putIfAbsent(prefixSum, i);
            }
        }
        
        return maxLength;
    }
}
