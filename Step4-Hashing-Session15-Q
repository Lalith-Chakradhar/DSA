https://leetcode.com/problems/count-number-of-pairs-with-absolute-difference-k/

class Solution {
    //Idea- Simplify the expression by removing the modulo |nums[i] - nums[j]| == k into +-(nums[i] - nums[j]) = k. Now keep adding frequency of elements from left to right in a hashmap  and simultaneously check whether (currentElement + k) or (currentElement - k) is present in the hashmap.
    
    //Algorithm - TC-O(n), SC-O(n)
    //1. Traverse array elements from left to right.
    //2. Check whether currentElement+k or currentElement-k is present in the hashmap. If present increment the count by taking the frequency.
    //3. Add the element frequency in the Hashmap.
    //4. Return the count.
    public int countKDifference(int[] nums, int k) {
        int count = 0;
        HashMap<Integer, Integer> freq = new HashMap<>();
        int n = nums.length;
        for(int i=0;i<n;i++)
        {
            int exp1 = nums[i]-k;
            int exp2 = nums[i]+k;
            if(freq.containsKey(exp1))
            {
                count += freq.get(exp1);
            }
            if(freq.containsKey(exp2))
            {
                count += freq.get(exp2);
            }
            
            freq.put(nums[i], freq.getOrDefault(nums[i],0)+1);
        }

        return count;
    }
}
