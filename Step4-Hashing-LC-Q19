https://leetcode.com/problems/maximum-number-of-subsequences-after-one-inserting/

class Solution {
    //Algorithm
    //1. We should first check three possible case insertions - 
        //'L' / 'C' / 'T'. Also remember we can insert 'C' in n+1 positions.
    //2. To maximize 'LCT' with 'L' insertion, we should maximize 'CT' suffix possibilities and suffix[i] should end at 'L'. So 'L' should be placed in the beginning.
    //3. To maximize 'LCT' with 'T' insertion, we should maximize 'LC' prefix
    //possiblities and prefix[i] should end at 'T'. So 'T' should be placed in the end.
    //4. To maximize 'LCT' with 'C' insertions, we should insert between L and T possibilities. Now check max "LCT" insertions with "L" insertion, "C" insertion and "T" insertion.
    public long numOfSubsequences(String s) {
        int n = s.length();

        if(n<2) return 0;
        
        long suffixTArray[] = new long[n+2];
        long prefixLArray[] = new long[n+2];

        long t = 0L;
        long ct = 0L;
        long countLCT = 0L;

        for(int i=n-1;i>=0; i--)
        {
            char ch = s.charAt(i);

            if(ch=='T')
            {
                t++;
            }
            if(ch=='C')
            {
                ct += t; 
            }
            if(ch=='L')
            {
                countLCT += ct;
            }

            suffixTArray[i] = t;
        }

        long lMax = countLCT + ct; //new + existing

        long l = 0L;
        long lc = 0L;
        for(int i=0;i<n; i++)
        {
            char ch = s.charAt(i);

            if(ch=='L')
            {
                l++;
            }
            if(ch=='C')
            {
                lc += l; 
            }

            prefixLArray[i] = l;
        }

        long tMax = lc+countLCT;

        long cMax = 0L;
        for (int i = 0; i<=n; i++) {
        long leftL = (i > 0) ? prefixLArray[i - 1] : 0;
        long rightT = (i < n) ? suffixTArray[i] : 0;

        cMax = Math.max(cMax, leftL * rightT + countLCT);
    }

        return Math.max(lMax, Math.max(cMax, tMax));
    }
}
