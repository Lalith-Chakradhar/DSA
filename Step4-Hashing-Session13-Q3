https://leetcode.com/problems/find-common-characters/

class Solution {

    //Algorithnm
    //1. Maintain a global minimum character frequency hashmap and add frequency of first word in it.
    //2. Now for each word, iterate and create a temp freq hashmap, store the characters frequency.
    //3. Iterate the global hashmap and tak min frequency of temp hashmap and global hashmap.
    //4. Count the global hashmap frequencies and store them in result array. Return the result.
    public List<String> commonChars(String[] words) {
        
        int n = words.length;

        if(n==0)
        {
            return new ArrayList<>();
        }

        if(n == 1) {
            List<String> result = new ArrayList<>();
            for(char c : words[0].toCharArray()) {
                result.add(String.valueOf(c));
            }
            return result;
        }

        HashMap<Character,Integer> globMinFreq = new HashMap<>();
        for(int i=0; i<words[0].length(); i++)
        {
            char ch = words[0].charAt(i);
            globMinFreq.put(ch, globMinFreq.getOrDefault(ch, 0)+1);
        }

        for(int i=1; i<n; i++)
        {
            String word = words[i];
            HashMap<Character,Integer> tempFreq = new HashMap<>();
            for(int j=0; j<word.length(); j++)
            {
                char ch = word.charAt(j);
                tempFreq.put(ch, tempFreq.getOrDefault(ch,0)+1);
            }

            for(char ch: globMinFreq.keySet())
            {
                globMinFreq.put(ch, Math.min(globMinFreq.getOrDefault(ch,0), tempFreq.getOrDefault(ch,0)));
            }
        }

        List<String> result = new ArrayList<>();
        for(char ch: globMinFreq.keySet())
        {
            int count = globMinFreq.get(ch);
            while(count > 0)
            {
                result.add(Character.toString(ch));
                count--;
            }
        }

        return result;       
    }
}
