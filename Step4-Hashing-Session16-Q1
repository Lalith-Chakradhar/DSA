class Solution {
    //Idea - Calculate prefix sum and store in hashmap.
    //If you want to find in between subarray sums, then we should know that -
    // (prefixSum - k) part + k part = currentPrefixSum. 
    //So if we are able to find (prefixSum - k) in hashmap
    // then we found the subarray sum which is equal to k.
    
    //Algorithm - TC - O(n), SC - O(n)
    //1. Calculate the prefix sum and store the frequency in hashmap.
    //2. If current prefix sum is k then increment the count.
    //3. If current prefix sum is not k, then try finding prefixSum-k in the hashmap.
    //4. If found, increment count by the frequency.
    //5. Store the prefix sum frequency in the hashmap.
    //6. Return the count.
    public int cntSubarrays(int[] arr, int k) {
        int count = 0;
        int prefixSum = 0;
        int n = arr.length;
        
        HashMap<Integer,Integer> freq = new HashMap<>();
        
        for(int i=0; i<n;i++)
        {
            prefixSum += arr[i];
            
            if(prefixSum==k)
            {
                count++;
            }
            
            if(freq.containsKey(prefixSum-k))
            {
                count += freq.get(prefixSum-k);
            }
            
            freq.put(prefixSum, freq.getOrDefault(prefixSum,0)+1);
        }
        
        return count;
    }
}
